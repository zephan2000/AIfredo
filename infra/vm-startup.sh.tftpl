#!/usr/bin/env bash
# AIfredo brain VM bootstrap.
# Rendered by templatefile() and run as GCE startup-script on first boot.
set -euxo pipefail

exec > >(tee -a /var/log/aifredo-bootstrap.log) 2>&1

# --- Swap (e2-micro has 1GB RAM; 2GB swap for safety) ---
if ! swapon --show | grep -q /swapfile; then
  fallocate -l 2G /swapfile
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi
echo 'vm.swappiness=10' > /etc/sysctl.d/99-aifredo.conf
sysctl -p /etc/sysctl.d/99-aifredo.conf

# --- Packages ---
export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y curl git build-essential jq ca-certificates

# --- Node 20 via NodeSource ---
if ! command -v node >/dev/null 2>&1 || ! node -v | grep -q '^v22'; then
  curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
  apt-get install -y nodejs
fi
npm install -g pnpm@9.12.0 @anthropic-ai/claude-code @openai/codex

# --- cloudflared ---
if ! command -v cloudflared >/dev/null 2>&1; then
  curl -fsSL -o /usr/local/bin/cloudflared \
    https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64
  chmod +x /usr/local/bin/cloudflared
fi

# --- Service user ---
if ! id aifredo >/dev/null 2>&1; then
  useradd -m -s /bin/bash -d /home/aifredo aifredo
fi

# --- CI deployer sudoers drop-in (WIF, scoped) ---
# OS Login maps the CI deployer service account to Linux user sa_<unique_id>.
# Grant it only the exact privilege the deploy workflow needs: become aifredo
# (to run git pull + pnpm) and restart the brain unit. Validated with visudo
# before install — an invalid drop-in breaks sudo system-wide.
TMPSUDO=$(mktemp)
cat > "$TMPSUDO" <<SUDOEOF
sa_${ci_sa_unique_id} ALL=(aifredo) NOPASSWD: /bin/bash, /usr/bin/bash
sa_${ci_sa_unique_id} ALL=(root) NOPASSWD: /bin/systemctl restart aifredo-brain.service, /usr/bin/systemctl restart aifredo-brain.service
SUDOEOF
chmod 0440 "$TMPSUDO"
if visudo -cf "$TMPSUDO" >/dev/null; then
  mv "$TMPSUDO" /etc/sudoers.d/aifredo-ci
else
  echo "WARNING: CI sudoers drop-in invalid; CI deploys will fail until fixed"
  rm -f "$TMPSUDO"
fi

# --- Repo checkout + build ---
mkdir -p /opt/AIfredo
chown aifredo:aifredo /opt/AIfredo
if [[ ! -d /opt/AIfredo/.git ]]; then
  sudo -u aifredo git clone ${repo_url} /opt/AIfredo
fi
cd /opt/AIfredo
sudo -u aifredo git fetch origin
sudo -u aifredo git checkout main
sudo -u aifredo git pull --ff-only origin main || true
sudo -u aifredo pnpm install --frozen-lockfile || sudo -u aifredo pnpm install
sudo -u aifredo pnpm --filter brain build || true   # brain may not exist yet on first boot

# --- /opt/AIfredo/.env (rw for root, r for aifredo group) ---
cat > /opt/AIfredo/.env <<ENVEOF
PORT=8080
BRAIN_BEARER_TOKEN=${brain_bearer_token}
SUPABASE_URL=${supabase_url}
SUPABASE_SERVICE_ROLE_KEY=${supabase_service_role_key}
VERCEL_INGEST_URL=${vercel_ingest_url}
DOMAIN=${domain}
CREDS_BUCKET=${creds_bucket}
INTEGRATION_TOKEN_KEY=${integration_token_key}
BINANCE_TESTNET_API_KEY=${binance_testnet_api_key}
BINANCE_TESTNET_API_SECRET=${binance_testnet_api_secret}
NODE_ENV=production
ENVEOF
chown root:aifredo /opt/AIfredo/.env
chmod 640 /opt/AIfredo/.env

# --- CLI credential snapshot passphrase (root-only) ---
cat > /opt/AIfredo/creds.key <<KEYEOF
${creds_passphrase}
KEYEOF
chown root:root /opt/AIfredo/creds.key
chmod 600 /opt/AIfredo/creds.key

# --- Snapshot script (cron-driven, every 6h) ---
cat > /opt/AIfredo/snapshot-creds.sh <<'SNAPEOF'
#!/usr/bin/env bash
set -euo pipefail
BUCKET="$(grep ^CREDS_BUCKET= /opt/AIfredo/.env | cut -d= -f2)"
SRC=/home/aifredo
[[ -f "$SRC/.claude/.credentials.json" || -f "$SRC/.codex/auth.json" ]] || { echo "$(date -Iseconds) no creds, skip"; exit 0; }
TOKEN=$(curl -fsSH "Metadata-Flavor: Google" "http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token" | jq -r .access_token)
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT
sudo -u aifredo tar -C "$SRC" -czf - .claude/.credentials.json .codex/auth.json 2>/dev/null \
  | openssl enc -aes-256-cbc -pbkdf2 -salt -pass file:/opt/AIfredo/creds.key -out "$TMP"
curl -fsS -X POST \
  "https://storage.googleapis.com/upload/storage/v1/b/$${BUCKET}/o?uploadType=media&name=snapshot-latest.tar.gz.enc" \
  -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/octet-stream" \
  --data-binary "@$TMP" >/dev/null
echo "$(date -Iseconds) snapshot ok ($(stat -c %s "$TMP")b)"
SNAPEOF
chmod 750 /opt/AIfredo/snapshot-creds.sh
chown root:root /opt/AIfredo/snapshot-creds.sh

cat > /etc/cron.d/aifredo-snapshot <<'CRONEOF'
0 */6 * * * root /opt/AIfredo/snapshot-creds.sh >> /var/log/aifredo-snapshot.log 2>&1
CRONEOF

# --- Let the brain (runs as aifredo) trigger a snapshot after each CLI run ---
# Scoped sudoers: aifredo may run only this one root script, no args. The
# script stays root-owned 750 so aifredo can't modify it. Validated before
# install — a broken drop-in disables sudo system-wide.
TMPSNAPSUDO=$(mktemp)
echo 'aifredo ALL=(root) NOPASSWD: /opt/AIfredo/snapshot-creds.sh' > "$TMPSNAPSUDO"
chmod 0440 "$TMPSNAPSUDO"
if visudo -cf "$TMPSNAPSUDO" >/dev/null; then
  mv "$TMPSNAPSUDO" /etc/sudoers.d/aifredo-snapshot
else
  echo "WARNING: aifredo-snapshot sudoers drop-in invalid; post-run snapshots disabled"
  rm -f "$TMPSNAPSUDO"
fi

# --- Restore CLI credentials from snapshot on fresh VM ---
# xtrace is suppressed across this block: the metadata SA access token and the
# Authorization: Bearer header would otherwise be written in cleartext to
# /var/log/aifredo-bootstrap.log (the script runs under `set -x`).
if [[ ! -f /home/aifredo/.claude/.credentials.json && ! -f /home/aifredo/.codex/auth.json ]]; then
  echo "No CLI credentials present; checking for snapshot in gs://${creds_bucket}..."
  set +x
  RESTORE_TOKEN=$(curl -fsSH "Metadata-Flavor: Google" "http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token" | jq -r .access_token || echo "")
  if [[ -n "$RESTORE_TOKEN" ]]; then
    STATUS=$(curl -sS -o /tmp/snap.enc -w "%%{http_code}" \
      "https://storage.googleapis.com/storage/v1/b/${creds_bucket}/o/snapshot-latest.tar.gz.enc?alt=media" \
      -H "Authorization: Bearer $RESTORE_TOKEN" || echo "fail")
    unset RESTORE_TOKEN
    if [[ "$STATUS" == "200" && -s /tmp/snap.enc ]]; then
      mkdir -p /home/aifredo/.claude /home/aifredo/.codex
      openssl enc -aes-256-cbc -d -pbkdf2 -pass file:/opt/AIfredo/creds.key -in /tmp/snap.enc \
        | tar -C /home/aifredo -xzf -
      chown -R aifredo:aifredo /home/aifredo/.claude /home/aifredo/.codex
      chmod 700 /home/aifredo/.claude /home/aifredo/.codex
      chmod 600 /home/aifredo/.claude/.credentials.json /home/aifredo/.codex/auth.json 2>/dev/null || true
      echo "Credentials restored from snapshot."
    else
      echo "No snapshot found (HTTP $STATUS); manual OAuth required."
    fi
    rm -f /tmp/snap.enc
  fi
  set -x
fi

# --- systemd: cloudflared tunnel ---
# Token written via sed to avoid template double-escaping inside the unit body.
cat > /etc/systemd/system/cloudflared.service <<'UNITEOF'
[Unit]
Description=Cloudflare Tunnel (AIfredo)
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/cloudflared tunnel run --token __TUNNEL_TOKEN__
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
UNITEOF
sed -i "s|__TUNNEL_TOKEN__|${tunnel_token}|" /etc/systemd/system/cloudflared.service

# --- systemd: brain ---
cat > /etc/systemd/system/aifredo-brain.service <<'UNITEOF'
[Unit]
Description=AIfredo Brain
After=network.target cloudflared.service

[Service]
Type=simple
User=aifredo
WorkingDirectory=/opt/AIfredo/apps/brain
EnvironmentFile=/opt/AIfredo/.env
ExecStart=/usr/bin/node --import tsx /opt/AIfredo/apps/brain/dist/server.js
Restart=on-failure
RestartSec=5s
MemoryMax=600M

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
systemctl enable --now cloudflared.service
# Brain may fail to start until CLIs are OAuth'd; that's fine, restart later.
systemctl enable aifredo-brain.service || true
systemctl start aifredo-brain.service || true

date -Iseconds > /var/run/aifredo-bootstrap-done
echo "AIfredo bootstrap complete."
