# Copy to terraform.tfvars and fill in.
# terraform.tfvars is gitignored.

# --- General ---
domain = "example.com"  # the apex domain you own in Cloudflare

# --- GCP ---
gcp_project_id      = "aifredo-123456"        # `gcloud projects create` first
gcp_region          = "us-west1"               # free e2-micro region
gcp_zone            = "us-west1-a"
gcp_billing_account = "012345-ABCDEF-GHIJKL"  # `gcloud billing accounts list`
tfstate_bucket_name = "aifredo-tfstate-<random-suffix>"  # must be globally unique
ssh_pub_key         = "ssh-ed25519 AAAA... your-email"

# --- Cloudflare ---
cloudflare_account_id = "abc123..."
cloudflare_zone_id    = "def456..."
cloudflare_api_token  = "redacted"  # Zone:DNS:Edit + Account:Cloudflare Tunnel:Edit

# --- Vercel ---
vercel_api_token = "redacted"  # https://vercel.com/account/tokens
# vercel_team_id = "team_..."  # only if using a team

# --- GitHub ---
github_owner     = "zephan2000"
github_token     = "redacted"  # PAT with `repo` + `workflow`
github_repo_name = "AIfredo"

# --- Supabase ---
supabase_access_token = "sbp_redacted"  # https://supabase.com/dashboard/account/tokens
supabase_org_id       = "your-org-slug"
supabase_db_password  = "redacted"  # generate a strong one; you can't change it later easily
supabase_region       = "us-west-1"

# --- Telegram ---
telegram_bot_token     = "redacted"  # @BotFather → /newbot
admin_telegram_user_id = "123456789"  # your numeric Telegram user ID (e.g. via @userinfobot)

# --- Binance (testnet first; trade-only key, withdrawals OFF, IP-allowlist the VM) ---
binance_testnet_api_key    = "redacted"  # testnet.binancefuture.com
binance_testnet_api_secret = "redacted"

# --- Tiger Brokers (paper account = testnet-equivalent; trade-only) ---
# Apply for Tiger Open API access, generate an RSA key pair, register the
# PUBLIC key with Tiger. Set ONE of the two private-key vars (pk8 wins if
# both): a quoted single-line bare base64 of the DER, OR a PEM heredoc.
# Set only one. Terraform base64-encodes it for VM transport. Leave
# tiger_live_account empty until live trading is separately armed.
tiger_id            = ""  # Tiger developer ID
tiger_paper_account = ""  # simulation account id (used when mode=testnet)
tiger_live_account  = ""  # live account id (used only when mode=live + armed)
# Bare base64-DER form (single line, must be quoted):
tiger_private_key_pk8 = ""
# ...or PEM heredoc form:
# tiger_private_key_pk8 = <<-EOT
# -----BEGIN PRIVATE KEY-----
# ...
# -----END PRIVATE KEY-----
# EOT
# tiger_private_key_pk1 = ""   # PKCS#1 alternative (used only if pk8 empty)
